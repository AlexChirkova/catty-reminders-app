[Unit]
Description=Catty Reminders FastAPI App
After=network.target

[Service]
User=kali
WorkingDirectory=/home/kali/catty-reminders-app
EnvironmentFile=/home/kali/catty-reminders-app/.env
ExecStart=/home/kali/catty-reminders-app/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
